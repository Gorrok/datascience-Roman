#!/usr/bin/expect -f

set timeout 30
set hostname "93.189.230.247"
set username "root"
set password "+2Z_fBbzk5PG"

puts "🧪 Тестируем member bot..."
spawn ssh -o StrictHostKeyChecking=no $username@$hostname
expect {
    "password:" {
        send "$password\r"
        expect "# "
        
        puts "✅ Подключение успешно"
        
        # Останавливаем старые процессы
        send "pkill -f 'beget_deployment 2' || echo 'Процессы остановлены'\r"
        expect "# "
        
        # Запускаем member bot
        send "cd \"/root/beget_deployment 2\" && source /root/bot_env/bin/activate && timeout 10 python bot.py 2>&1\r"
        expect "# "
        
        puts "✅ Тест завершен"
        
    }
    "Permission denied" {
        puts "❌ Ошибка аутентификации"
        exit 1
    }
    timeout {
        puts "⏰ Таймаут подключения"
        exit 1
    }
}
