# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/telegram_analytics
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/telegram_analytics

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (для верификации и сброса пароля)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@telegram-analytics.com
EMAILS_FROM_NAME=Telegram Analytics

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App
APP_NAME=Telegram Analytics
FRONTEND_URL=http://localhost:3000

# Environment
ENVIRONMENT=development
