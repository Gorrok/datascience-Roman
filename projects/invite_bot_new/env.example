# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel ID (получить можно через @username_to_id_bot)
# Для приватных каналов используйте формат: -100XXXXXXXXXX
CHANNEL_ID=-1001234567890

# Google Sheets Configuration
SPREADSHEET_NAME=InviteTracking
CREDENTIALS_FILE=credentials.json

# Logging
LOG_LEVEL=INFO
