# ✅ ХОРОШО - разделение ответственности
class UserRepository:
    """Работа с БД"""
    def create(self, data): ...
    def update(self, user_id, data): ...
    def delete(self, user_id): ...
    def get(self, user_id): ...

class UserStatsService:
