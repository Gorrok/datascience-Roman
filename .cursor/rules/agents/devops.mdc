### 3. Настройка логирования
```python
# В боте
import logging
from logging.handlers import RotatingFileHandler

# Настройка логирования
def setup_logging():
    logger = logging.getLogger()
    logger.setLevel(logging.INFO)
    
    # В файл (с ротацией)
    file_handler = RotatingFileHandler(
        'bot.log',
        maxBytes=10*1024*1024,  # 10MB
        backupCount=5
    )
    file_handler.setFormatter(
        logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - %(message)s')
    )
    logger.addHandler(file_handler)
    
    # В консоль
    console_handler = logging.StreamHandler()
    console_handler.setFormatter(
        logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
    )
    logger.addHandler(console_handler)

# В main
if __name__ == '__main__':
    setup_logging()
    logging.info("Bot starting...")
```

### 4. Backup базы данных
```bash
# Скрипт backup.sh
#!/bin/bash
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="/home/username/backups"
DB_PATH="/home/username/bots/mybot/bot.db"

mkdir -p $BACKUP_DIR

# Для SQLite
cp $DB_PATH "$BACKUP_DIR/bot_$DATE.db"

# Для PostgreSQL
# pg_dump -U user dbname > "$BACKUP_DIR/db_$DATE.sql"

# Удалить старые (>7 дней)
find $BACKUP_DIR -name "bot_*.db" -mtime +7 -delete

echo "Backup created: bot_$DATE.db"

# Добавить в crontab (каждый день в 3:00)
# 0 3 * * * /home/username/backup.sh
```

## 📊 Мониторинг

### Проверка здоровья
```bash
# Скрипт health_check.sh
#!/bin/bash

# Проверить что сервис запущен
if systemctl is-active --quiet mybot; then
    echo "✅ Bot is running"
else
    echo "❌ Bot is down!"
    # Можно отправить уведомление
    # curl -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
    #   -d "chat_id=$ADMIN_ID" \
    #   -d "text=🚨 Bot is down!"
    
    # Попробовать перезапустить
    sudo systemctl start mybot
fi

# Проверить логи на ошибки
errors=$(sudo journalctl -u mybot --since "1 hour ago" | grep ERROR | wc -l)
if [ $errors -gt 0 ]; then
    echo "⚠️ Found $errors errors in logs"
fi
```

## 🔒 Безопасность

### 1. Firewall
```bash
# UFW (Ubuntu)
sudo ufw allow 22    # SSH
sudo ufw allow 80    # HTTP
sudo ufw allow 443   # HTTPS
sudo ufw enable
```

### 2. SSH ключи
```bash
# Генерация ключа (на локальной машине)
ssh-keygen -t ed25519 -C "your_email@example.com"

# Копирование на сервер
ssh-copy-id username@hostname

# Отключить пароли в SSH (на сервере)
sudo nano /etc/ssh/sshd_config
# PasswordAuthentication no
sudo systemctl restart sshd
```

### 3. Переменные окружения
```bash
# НИКОГДА не коммитить .env!
# Добавить в .gitignore
echo ".env" >> .gitignore

# На сервере хранить в безопасном месте
chmod 600 .env
```

