# -*- coding: utf-8 -*-

"""
Пример файла с секретными ключами для Fishing Agent

ИНСТРУКЦИЯ:
1. Скопируйте этот файл: cp secrets.py.example secrets.py
2. Заполните все значения своими реальными ключами
3. secrets.py добавлен в .gitignore - не коммитьте его!
"""

# YouTube API
# Получить: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY = "your_youtube_api_key_here"

# Telegram API
# Получить: https://my.telegram.org/apps
TELEGRAM_API_ID = 12345678  # Ваш API ID (число)
TELEGRAM_API_HASH = "your_telegram_api_hash_here"  # Ваш API Hash

# OpenAI API (опционально)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY = "your_openai_api_key_here"

# GitHub API (опционально)
# Получить: https://github.com/settings/tokens
GITHUB_TOKEN = "your_github_token_here"
GITHUB_REPO = "your_username/repository_name"
